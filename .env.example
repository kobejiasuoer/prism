# Prism local environment template.
# Copy to `.env` and adjust per-host overrides. Do NOT commit `.env`.
# Loaded by start_prism.sh BEFORE any variable defaults are computed.

# --- Backend (FastAPI control-panel) ---
# PRISM_APP_MODULE=control_panel.app:app
# PRISM_BACKEND_HOST=127.0.0.1
# PRISM_BACKEND_PORT=8001
# PRISM_BACKEND_ORIGIN=http://127.0.0.1:8001

# --- Web (Next.js apps/web) ---
# PRISM_WEB_HOST=127.0.0.1
# PRISM_WEB_PORT=8000

# --- Scheduler ---
# PRISM_ENABLE_SCHEDULER=1
# PRISM_SCHEDULER_INTERVAL_SECONDS=20

# --- Data providers (set as needed; no defaults shipped) ---
# PRISM_TUSHARE_TOKEN=
# PRISM_AKSHARE_TIMEOUT=
